{{ 'about-designers.css' | asset_url | stylesheet_tag }}

{%- assign adp_slug_1 = block.settings.slug_1 | strip -%}
{%- assign adp_slug_2 = block.settings.slug_2 | strip -%}
{%- assign adp_slug_3 = block.settings.slug_3 | strip -%}
{%- assign adp_slug_4 = block.settings.slug_4 | strip -%}
{%- assign adp_slug_5 = block.settings.slug_5 | strip -%}

{%- assign adp_slugs_list = adp_slug_1 -%}
{%- if adp_slug_2 != blank -%}{%- assign adp_slugs_list = adp_slugs_list | append: ',' | append: adp_slug_2 -%}{%- endif -%}
{%- if adp_slug_3 != blank -%}{%- assign adp_slugs_list = adp_slugs_list | append: ',' | append: adp_slug_3 -%}{%- endif -%}
{%- if adp_slug_4 != blank -%}{%- assign adp_slugs_list = adp_slugs_list | append: ',' | append: adp_slug_4 -%}{%- endif -%}
{%- if adp_slug_5 != blank -%}{%- assign adp_slugs_list = adp_slugs_list | append: ',' | append: adp_slug_5 -%}{%- endif -%}

<section class="adp-section" style="--eyebrow-size: {{ block.settings.eyebrow_font_size }}px;">
  <div class="adp-inner">

    {%- if block.settings.eyebrow != blank -%}
      <div class="adp-eyebrow">{{- block.settings.eyebrow -}}</div>
    {%- endif -%}

    {%- if block.settings.heading != blank -%}
      <h2 class="adp-heading">{{- block.settings.heading -}}</h2>
    {%- endif -%}

    {%- if block.settings.lead != blank -%}
      <div class="adp-lead">{{- block.settings.lead -}}</div>
    {%- endif -%}

    <div class="adp-tiles"
      data-adp-block="{{ block.id }}"
      data-adp-slugs="{{ adp_slugs_list | escape }}"
      data-proxy-base="/apps/fabric-shop/api"
      data-profile-base="{{ block.settings.studio_page_url | default: '/pages/partners' | escape }}">

      <figure class="adp-tile adp-tile--1"{% if adp_slug_1 != blank %} data-adp-slug="{{ adp_slug_1 | escape }}"{% endif %}>
        {%- if adp_slug_1 != blank -%}
          <div class="adp-tile-art adp-tile-art--skel"></div>
          <figcaption class="adp-tile-cap adp-tile-cap--skel"></figcaption>
        {%- else -%}
          <div class="adp-tile-art adp-tile-art--placeholder"></div>
        {%- endif -%}
      </figure>

      <figure class="adp-tile adp-tile--2"{% if adp_slug_2 != blank %} data-adp-slug="{{ adp_slug_2 | escape }}"{% endif %}>
        {%- if adp_slug_2 != blank -%}
          <div class="adp-tile-art adp-tile-art--skel"></div>
          <figcaption class="adp-tile-cap adp-tile-cap--skel"></figcaption>
        {%- else -%}
          <div class="adp-tile-art adp-tile-art--placeholder"></div>
        {%- endif -%}
      </figure>

      <figure class="adp-tile adp-tile--3"{% if adp_slug_3 != blank %} data-adp-slug="{{ adp_slug_3 | escape }}"{% endif %}>
        {%- if adp_slug_3 != blank -%}
          <div class="adp-tile-art adp-tile-art--skel"></div>
          <figcaption class="adp-tile-cap adp-tile-cap--skel"></figcaption>
        {%- else -%}
          <div class="adp-tile-art adp-tile-art--placeholder"></div>
        {%- endif -%}
      </figure>

      <figure class="adp-tile adp-tile--4"{% if adp_slug_4 != blank %} data-adp-slug="{{ adp_slug_4 | escape }}"{% endif %}>
        {%- if adp_slug_4 != blank -%}
          <div class="adp-tile-art adp-tile-art--skel"></div>
          <figcaption class="adp-tile-cap adp-tile-cap--skel"></figcaption>
        {%- else -%}
          <div class="adp-tile-art adp-tile-art--placeholder"></div>
        {%- endif -%}
      </figure>

      <figure class="adp-tile adp-tile--5"{% if adp_slug_5 != blank %} data-adp-slug="{{ adp_slug_5 | escape }}"{% endif %}>
        {%- if adp_slug_5 != blank -%}
          <div class="adp-tile-art adp-tile-art--skel"></div>
          <figcaption class="adp-tile-cap adp-tile-cap--skel"></figcaption>
        {%- else -%}
          <div class="adp-tile-art adp-tile-art--placeholder"></div>
        {%- endif -%}
      </figure>

    </div>

    {%- if block.settings.link_url != blank and block.settings.link_label != blank -%}
      <a href="{{ block.settings.link_url }}" class="adp-link">{{- block.settings.link_label -}}</a>
    {%- endif -%}

  </div>
</section>

<script src="{{ 'about-designers.js' | asset_url }}" defer></script>

{% schema %}
{"name":"About — Designers","target":"section","settings":[
  {"type":"text","id":"eyebrow","label":"Eyebrow","default":"PrintLab · the Design Partner Programme"},
  {"type":"range","id":"eyebrow_font_size","label":"Eyebrow font size","min":8,"max":20,"step":1,"unit":"px","default":13},
  {"type":"richtext","id":"heading","label":"Heading","default":"<p>The studios behind <em>every print.</em></p>"},
  {"type":"richtext","id":"lead","label":"Lead paragraph","default":"<p>Every print on PrintLab comes from an independent designer running their own studio on the platform — a Design Partner who earns on every metre. <strong>Choose a print, choose a base, and we make it to order.</strong></p>"},
  {"type":"header","content":"Studios"},
  {"type":"text","id":"slug_1","label":"Studio 1 — slug","info":"Partner slug, e.g. meadow-and-thread"},
  {"type":"text","id":"slug_2","label":"Studio 2 — slug"},
  {"type":"text","id":"slug_3","label":"Studio 3 — slug"},
  {"type":"text","id":"slug_4","label":"Studio 4 — slug"},
  {"type":"text","id":"slug_5","label":"Studio 5 — slug"},
  {"type":"url","id":"studio_page_url","label":"Studio profile page URL","info":"Defaults to /pages/partners — ?handle=slug appended per tile"},
  {"type":"header","content":"Link"},
  {"type":"text","id":"link_label","label":"Link label","default":"Browse the studios →"},
  {"type":"url","id":"link_url","label":"Link URL"}
]}
{% endschema %}
