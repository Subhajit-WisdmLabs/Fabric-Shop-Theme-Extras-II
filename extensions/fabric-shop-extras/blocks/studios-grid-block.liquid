{{ 'studios-grid.css' | asset_url | stylesheet_tag }}
{%- assign sgb_profile = block.settings.profile_page_url | default: '/pages/partners' -%}
{%- assign sgb_per_page = block.settings.per_page | default: 3 -%}
<div class="sgb-wrap" id="sgb-{{ block.id }}" style="--eyebrow-size: {{ block.settings.eyebrow_font_size }}px;" data-sgb-block="{{ block.id }}" data-proxy-base="/apps/fabric-shop/api" data-profile-url="{{ sgb_profile | escape }}" data-per-page="{{ sgb_per_page }}">
  <div class="sgb-mod-head"><div class="sgb-mod-head-row"><div><div class="sgb-mod-eyebrow">All studios</div><h2 class="sgb-mod-title">The <em>studios</em>.</h2><p class="sgb-mod-sub">Independent designers from ten countries. Click through to a studio to see its full body of work.</p></div><div class="sgb-mod-count" id="sgb-mod-count-{{ block.id }}"></div></div></div>
  <div class="sgb-filter-bar" id="sgb-filter-bar-{{ block.id }}">
    <div class="sgb-filter-label-wrap">
      <span class="sgb-filter-label">Discipline</span>
      <span class="sgb-filter-count" id="sgb-filter-count-{{ block.id }}"></span>
    </div>
    <div class="sgb-pills" id="sgb-pills-{{ block.id }}">
      <button type="button" class="sgb-pill active" data-discipline="">All</button>
    </div>
  </div>
  <div class="sgb-grid" id="sgb-grid-{{ block.id }}"></div>
  <div class="sgb-pagination" id="sgb-pagination-{{ block.id }}" hidden>
    <button type="button" class="sgb-pag-btn sgb-pag-prev" id="sgb-pag-prev-{{ block.id }}" aria-label="Previous page">&#8592; Previous</button>
    <span class="sgb-pag-info" id="sgb-pag-info-{{ block.id }}"></span>
    <button type="button" class="sgb-pag-btn sgb-pag-next" id="sgb-pag-next-{{ block.id }}" aria-label="Next page">Next &#8594;</button>
  </div>
</div>
<script src="{{ 'studios-grid.js' | asset_url }}" defer></script>
{% schema %}
{"name":"Studios Grid","target":"section","settings":[
  {"type":"url","id":"profile_page_url","label":"Studio profile page URL","info":"Handle query param appended automatically"},
  {"type":"range","id":"per_page","label":"Studios per page","min":1,"max":12,"step":1,"default":3},
  {"type":"range","id":"eyebrow_font_size","label":"Eyebrow font size","min":8,"max":20,"step":1,"unit":"px","default":13}
]}
{% endschema %}
