{{ 'studios-grid.css' | asset_url | stylesheet_tag }}
{%- assign sgb_profile = block.settings.profile_page_url | default: '/pages/partners' -%}
{%- assign sgb_per_page = block.settings.per_page | default: 9 -%}
<div class="sgb-wrap" id="sgb-{{ block.id }}" data-sgb-block="{{ block.id }}" data-proxy-base="/apps/fabric-shop/api" data-profile-url="{{ sgb_profile | escape }}" data-per-page="{{ sgb_per_page }}">
  <div class="sgb-mod-head"><div class="sgb-mod-head-row"><div><div class="sgb-mod-eyebrow">All studios</div><h2 class="sgb-mod-title">The <em>studios</em>.</h2><p class="sgb-mod-sub">Independent designers from ten countries. Click through to a studio to see its full body of work.</p></div><div class="sgb-mod-count" id="sgb-mod-count-{{ block.id }}"></div></div></div>
  <div class="sgb-filter-bar" id="sgb-filter-bar-{{ block.id }}">
    <span class="sgb-filter-label">Discipline</span>
    <div class="sgb-pills" id="sgb-pills-{{ block.id }}">
      <button type="button" class="sgb-pill active" data-discipline="">All</button>
    </div>
  </div>
  <div class="sgb-count-row"><span class="sgb-count" id="sgb-count-{{ block.id }}">Loading&hellip;</span></div>
  <div class="sgb-grid" id="sgb-grid-{{ block.id }}"></div>
  <div class="sgb-load-more" id="sgb-load-more-{{ block.id }}" hidden>
    <button type="button" class="sgb-load-btn" id="sgb-load-btn-{{ block.id }}">Show more studios</button>
    <p class="sgb-load-count" id="sgb-load-count-{{ block.id }}"></p>
  </div>
</div>
<script src="{{ 'studios-grid.js' | asset_url }}" defer></script>
{% schema %}{"name":"Studios Grid","target":"section","settings":[{"type":"url","id":"profile_page_url","label":"Studio profile page URL","info":"Handle query param appended automatically"},{"type":"range","id":"per_page","label":"Studios per load","min":3,"max":24,"step":3,"default":9}]}{% endschema %}
