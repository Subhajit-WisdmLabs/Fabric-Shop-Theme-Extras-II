{{ 'studios-grid.css' | asset_url | stylesheet_tag }}
{%- assign sgb_profile = block.settings.profile_page_url | default: '/pages/partners' -%}
{%- assign sgb_per_page = block.settings.per_page | default: 9 -%}
<div class="sgb-wrap" id="sgb-{{ block.id }}" data-sgb-block="{{ block.id }}" data-proxy-base="/apps/fabric-shop/api" data-profile-url="{{ sgb_profile | escape }}" data-per-page="{{ sgb_per_page }}">
  <div class="sgb-mod-head">
    <div class="sgb-mod-head-row">
      <div>
        <div class="sgb-mod-eyebrow">All studios</div>
        <h2 class="sgb-mod-title">The <em>studios</em>.</h2>
        <p class="sgb-mod-sub">Independent designers from ten countries. Click through to a studio to see its full body of work.</p>
      </div>
      <div class="sgb-mod-count" id="sgb-mod-count-{{ block.id }}"></div>
    </div>
  </div>
  <div class="sgb-content" id="sgb-content-{{ block.id }}">
    <aside class="sgb-sidebar" id="sgb-sidebar-{{ block.id }}" aria-label="Studio filters">
      <div class="sgb-sidebar-head">
        <span class="sgb-sidebar-label">Filter</span>
        <button class="sgb-sidebar-close" id="sgb-sidebar-close-{{ block.id }}" aria-label="Close filters">✕</button>
      </div>
      <div class="sgb-sidebar-group" id="sgb-discipline-group-{{ block.id }}">
        <div class="sgb-sidebar-group-head">
          <span class="sgb-sidebar-group-name">Discipline</span>
          <span class="sgb-sidebar-group-toggle">−</span>
        </div>
        <div class="sgb-pills sgb-pills--vertical" id="sgb-pills-{{ block.id }}">
          <button type="button" class="sgb-pill active" data-discipline="">All</button>
        </div>
      </div>
    </aside>
    <div class="sgb-main">
      <div class="sgb-toolbar">
        <button class="sgb-filter-toggle" id="sgb-filter-toggle-{{ block.id }}">
          <svg width="14" height="12" viewBox="0 0 14 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><line x1="1" y1="1.5" x2="13" y2="1.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/><line x1="3" y1="6" x2="11" y2="6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/><line x1="5" y1="10.5" x2="9" y2="10.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
          Filter
        </button>
      </div>
      <div class="sgb-grid" id="sgb-grid-{{ block.id }}"></div>
      <div class="sgb-load-more" id="sgb-load-more-{{ block.id }}" hidden>
        <button type="button" class="sgb-load-btn" id="sgb-load-btn-{{ block.id }}">Show more studios</button>
        <p class="sgb-load-count" id="sgb-load-count-{{ block.id }}"></p>
      </div>
    </div>
  </div>
</div>
<script src="{{ 'studios-grid.js' | asset_url }}" defer></script>
{% schema %}{"name":"Studios Grid","target":"section","settings":[{"type":"url","id":"profile_page_url","label":"Studio profile page URL","info":"Handle query param appended automatically"},{"type":"range","id":"per_page","label":"Studios per load","min":3,"max":24,"step":3,"default":9}]}{% endschema %}
