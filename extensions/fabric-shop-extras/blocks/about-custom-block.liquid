{{ 'about-custom.css' | asset_url | stylesheet_tag }}

<section class="ac-section">
  <div class="ac-inner{% if block.settings.padding_size == 'reduced' %} ac-inner--reduced{% endif %}">
    <div class="ac-content">

      {%- if block.settings.eyebrow != blank -%}
        <div class="ac-eyebrow">{{- block.settings.eyebrow -}}</div>
      {%- endif -%}

      {%- if block.settings.heading != blank -%}
        <h2 class="ac-heading">{{- block.settings.heading -}}</h2>
      {%- endif -%}

      {%- if block.settings.body != blank -%}
        <div class="ac-body">{{- block.settings.body -}}</div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Custom",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "About Custom"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Your design, printed by the metre.</p>"
    },
    {
      "type": "select",
      "id": "padding_size",
      "label": "Vertical padding",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "reduced", "label": "Reduced" }
      ]
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Custom is for the design you've already made — a brand pattern, a wedding motif, a one-off print, a repeat you've drawn and want to see on cotton. Bring the file. We handle the rest.</p><p>Most designs upload right here — drop the file in for a live tile-test at your fabric's print width, and an automatic print-quality check before you commit. Larger or print-ready files don't go through the site — <strong>email them to us</strong> and we set the order up by hand. Either way — the same twenty base fabrics, the same 7–10 day print window, and the QC we built supplying the trade.</p>"
    }
  ]
}
{% endschema %}
