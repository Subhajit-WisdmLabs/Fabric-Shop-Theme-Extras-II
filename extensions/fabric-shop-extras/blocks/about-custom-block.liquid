{{ 'about-custom.css' | asset_url | stylesheet_tag }}

<section class="ac-section">
  <div class="ac-inner" style="--ac-pad-y: {{ block.settings.padding_y | default: 88 }}px; --eyebrow-size: {{ block.settings.eyebrow_font_size }}px;">
    <div class="ac-content">

      {%- if block.settings.eyebrow != blank -%}
        <div class="ac-eyebrow">{{- block.settings.eyebrow -}}</div>
      {%- endif -%}

      {%- if block.settings.heading != blank -%}
        <h2 class="ac-heading">
          {{- block.settings.heading | strip_html -}}
          {%- if block.settings.heading_emphasis != blank -%}
            <em style="color:{{ block.settings.emphasis_color }};">{{ block.settings.heading_emphasis }}</em>
          {%- endif -%}
        </h2>
      {%- endif -%}

      {%- if block.settings.body != blank -%}
        <div class="ac-body">{{- block.settings.body -}}</div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{"name":"About Custom","target":"section","settings":[
  {"type":"text","id":"eyebrow","label":"Eyebrow text","default":"About Custom"},
  {"type":"range","id":"eyebrow_font_size","label":"Eyebrow font size","min":8,"max":20,"step":1,"unit":"px","default":13},
  {"type":"text","id":"heading","label":"Heading","default":"Your design, printed by the metre."},
  {"type":"text","id":"heading_emphasis","label":"Heading emphasis (italic)"},
  {"type":"color","id":"emphasis_color","label":"Emphasis colour","default":"#5C7355"},
  {"type":"range","id":"padding_y","label":"Vertical padding","min":24,"max":120,"step":8,"unit":"px","default":88},
  {"type":"richtext","id":"body","label":"Body text","default":"<p>Custom is for the design you've already made — a brand pattern, a wedding motif, a one-off print, a repeat you've drawn and want to see on cotton. Bring the file. We handle the rest.</p><p>Most designs upload right here — drop the file in for a live tile-test at your fabric's print width, and an automatic print-quality check before you commit. Larger or print-ready files don't go through the site — <strong>email them to us</strong> and we set the order up by hand. Either way — the same twenty base fabrics, the same 7–10 day print window, and the QC we built supplying the trade.</p>"}
]}
{% endschema %}
