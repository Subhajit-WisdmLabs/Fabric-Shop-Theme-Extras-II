{{ 'printing-methods.css' | asset_url | stylesheet_tag }}

<section class="pm-section">
  <div class="pm-inner">

    <div class="pm-head">
      {%- if block.settings.eyebrow != blank -%}
        <p class="pm-eyebrow">{{- block.settings.eyebrow -}}</p>
      {%- endif -%}
      {%- if block.settings.title != blank -%}
        <h2 class="pm-title">{{- block.settings.title | remove: '<p>' | remove: '</p>' -}}</h2>
      {%- endif -%}
      {%- if block.settings.sub != blank -%}
        <p class="pm-sub">{{- block.settings.sub -}}</p>
      {%- endif -%}
    </div>

    <div class="pm-grid">
      {%- for i in (1..2) -%}
        {%- assign eb_key   = 'method_' | append: i | append: '_eyebrow' -%}
        {%- assign name_key = 'method_' | append: i | append: '_name' -%}
        {%- assign desc_key = 'method_' | append: i | append: '_desc' -%}
        <div class="pm-method">
          {%- if block.settings[eb_key] != blank -%}
            <p class="pm-method__eb">{{- block.settings[eb_key] -}}</p>
          {%- endif -%}
          {%- if block.settings[name_key] != blank -%}
            <h3 class="pm-method__name">{{- block.settings[name_key] | remove: '<p>' | remove: '</p>' -}}</h3>
          {%- endif -%}
          {%- if block.settings[desc_key] != blank -%}
            <p class="pm-method__desc">{{- block.settings[desc_key] -}}</p>
          {%- endif -%}
          <dl class="pm-specs">
            {%- for n in (1..3) -%}
              {%- assign sk = 'method_' | append: i | append: '_spec' | append: n | append: '_key' -%}
              {%- assign sv = 'method_' | append: i | append: '_spec' | append: n | append: '_val' -%}
              {%- if block.settings[sk] != blank -%}
                <div class="pm-spec-row">
                  <dt class="pm-spec-key">{{- block.settings[sk] -}}</dt>
                  <dd class="pm-spec-val">{{- block.settings[sv] -}}</dd>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </dl>
        </div>
      {%- endfor -%}
    </div>

    {%- if block.settings.foot_label != blank -%}
      <p class="pm-foot">
        <a href="{{ block.settings.foot_url | default: '#' }}" class="pm-foot__link">
          {{- block.settings.foot_label -}}
        </a>
      </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Printing Methods",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Two ways your fabric is printed"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "info": "Use italic in the editor for the accent word.",
      "default": "<p>Reactive for naturals. <em>Sublimation<\/em> for synthetics.<\/p>"
    },
    {
      "type": "textarea",
      "id": "sub",
      "label": "Sub text",
      "default": "Every printed order uses one of two methods, matched to the fibre of the base you choose. Both bond the ink into the fabric itself — not onto the surface — so the colour won't crack or peel, and your fabric still feels like fabric."
    },
    {
      "type": "header",
      "content": "Method 1"
    },
    {
      "type": "text",
      "id": "method_1_eyebrow",
      "label": "Eyebrow",
      "default": "For natural fibres"
    },
    {
      "type": "richtext",
      "id": "method_1_name",
      "label": "Method name",
      "info": "Italicise the first word.",
      "default": "<p><em>Reactive<\/em> dye printing<\/p>"
    },
    {
      "type": "textarea",
      "id": "method_1_desc",
      "label": "Description",
      "default": "The dye reacts with the fibre and becomes part of it — deep, lasting colour with the fabric's natural softness untouched."
    },
    {
      "type": "text",
      "id": "method_1_spec1_key",
      "label": "Spec 1 — label",
      "default": "Your bases"
    },
    {
      "type": "text",
      "id": "method_1_spec1_val",
      "label": "Spec 1 — value",
      "default": "Cotton, linen, silk, wool, viscose"
    },
    {
      "type": "text",
      "id": "method_1_spec2_key",
      "label": "Spec 2 — label",
      "default": "Colour"
    },
    {
      "type": "text",
      "id": "method_1_spec2_val",
      "label": "Spec 2 — value",
      "default": "Deep and rich — holds through washing"
    },
    {
      "type": "text",
      "id": "method_1_spec3_key",
      "label": "Spec 3 — label",
      "default": "The feel"
    },
    {
      "type": "text",
      "id": "method_1_spec3_val",
      "label": "Spec 3 — value",
      "default": "Soft — the hand of the fabric, unchanged"
    },
    {
      "type": "header",
      "content": "Method 2"
    },
    {
      "type": "text",
      "id": "method_2_eyebrow",
      "label": "Eyebrow",
      "default": "For synthetic fibres"
    },
    {
      "type": "richtext",
      "id": "method_2_name",
      "label": "Method name",
      "info": "Italicise the first word.",
      "default": "<p><em>Sublimation<\/em> printing<\/p>"
    },
    {
      "type": "textarea",
      "id": "method_2_desc",
      "label": "Description",
      "default": "Heat fuses the ink into the fibre — sharp detail and vivid colour, locked in for good."
    },
    {
      "type": "text",
      "id": "method_2_spec1_key",
      "label": "Spec 1 — label",
      "default": "Your bases"
    },
    {
      "type": "text",
      "id": "method_2_spec1_val",
      "label": "Spec 1 — value",
      "default": "Polyester and polyester blends"
    },
    {
      "type": "text",
      "id": "method_2_spec2_key",
      "label": "Spec 2 — label",
      "default": "Colour"
    },
    {
      "type": "text",
      "id": "method_2_spec2_val",
      "label": "Spec 2 — value",
      "default": "Vivid and sharp — fade-resistant"
    },
    {
      "type": "text",
      "id": "method_2_spec3_key",
      "label": "Spec 3 — label",
      "default": "The feel"
    },
    {
      "type": "text",
      "id": "method_2_spec3_val",
      "label": "Spec 3 — value",
      "default": "Light — no coating, no added stiffness"
    },
    {
      "type": "header",
      "content": "Footer link"
    },
    {
      "type": "text",
      "id": "foot_label",
      "label": "Link label",
      "default": "Full method detail base by base — plus file setup and colour matching — lives in the FAQs →"
    },
    {
      "type": "url",
      "id": "foot_url",
      "label": "Link URL"
    }
  ]
}
{% endschema %}
