{{ 'custom-upload-bridge.css' | asset_url | stylesheet_tag }}

<div class="cub-wrap" style="background:{{ block.settings.bg_color }};">
  <div class="cub-inner">

    <!-- Left: copy + CTA -->
    <div>
      {%- if block.settings.eyebrow != blank -%}
        <p class="cub-eyebrow" style="color:{{ block.settings.accent_color }};">
          {{- block.settings.eyebrow -}}
        </p>
      {%- endif -%}

      <h2 class="cub-title" style="color:{{ block.settings.heading_color }};">
        {{- block.settings.heading -}}
      </h2>

      {%- if block.settings.body_copy != blank -%}
        <p class="cub-sub" style="color:{{ block.settings.body_color }};">
          {{- block.settings.body_copy -}}
        </p>
      {%- endif -%}

      {%- if block.settings.cta_label != blank -%}
        <a
          class="cub-cta"
          style="--cub-cta-bg:{{ block.settings.cta_bg_color }};--cub-cta-fg:{{ block.settings.cta_text_color }};--cub-cta-hover-bg:{{ block.settings.cta_hover_bg_color }};--cub-cta-hover-fg:{{ block.settings.cta_hover_text_color }};"
          {% if block.settings.cta_url != blank %}href="{{ block.settings.cta_url }}"{% endif %}
        >
          {{- block.settings.cta_label -}}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <!-- Right: image or fallback tile grid -->
    {%- if block.settings.image != blank -%}
      <div class="cub-image-wrap">
        {{
          block.settings.image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            class: 'cub-image',
            widths: '400, 600, 800',
            sizes: '(max-width: 900px) 100vw, 45vw',
            alt: block.settings.image.alt | escape
        }}
      </div>
    {%- else -%}
      <div class="cub-art" aria-hidden="true">
        <div class="cub-tile cub-tile--filled-1"></div>
        <div class="cub-tile cub-tile--empty" style="color:{{ block.settings.accent_color }};">YOUR</div>
        <div class="cub-tile cub-tile--filled-2"></div>
        <div class="cub-tile cub-tile--empty" style="color:{{ block.settings.accent_color }};">FILE</div>
        <div class="cub-tile cub-tile--filled-3"></div>
        <div class="cub-tile cub-tile--empty" style="color:{{ block.settings.accent_color }};">HERE</div>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Custom Upload Bridge",
  "target": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Closing bridge that re-routes browsing customers into the Custom Upload Wizard. Place after the design grid or before the footer."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Don't see your idea?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Print your own design."
    },
    {
      "type": "textarea",
      "id": "body_copy",
      "label": "Body copy",
      "default": "Upload your file, set the repeat, choose your base fabric. A live preview shows you exactly what arrives — before you commit a single metre."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Upload a design"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "header",
      "content": "Right-side image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Replaces the decorative tile grid. Recommended: square or portrait, min 800px wide."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#F4ECDA"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (eyebrow & tile labels)",
      "default": "#A87A2E"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#1A1814"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text",
      "default": "#5C564A"
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "CTA background",
      "default": "#1A1814"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "CTA text",
      "default": "#FAF8F3"
    },
    {
      "type": "color",
      "id": "cta_hover_bg_color",
      "label": "CTA hover background",
      "default": "#A87A2E"
    },
    {
      "type": "color",
      "id": "cta_hover_text_color",
      "label": "CTA hover text",
      "default": "#FAF8F3"
    }
  ]
}
{% endschema %}
