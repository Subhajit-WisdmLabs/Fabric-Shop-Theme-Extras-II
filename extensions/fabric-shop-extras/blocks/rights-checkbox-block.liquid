{{ 'rights-checkbox.css' | asset_url | stylesheet_tag }}

<div class="rcb-block" id="rcb-block-{{ block.id }}">
  <div class="rcb-row" id="rcb-row-{{ block.id }}" role="checkbox" aria-checked="false" tabindex="0">
    <div class="rcb-checkbox"></div>
    <div class="rcb-label">{{ block.settings.checkbox_label }}</div>
  </div>

  {%- if block.settings.confirm_details != blank -%}
    <button type="button" class="rcb-disclosure" id="rcb-disclosure-{{ block.id }}"
            aria-expanded="false" aria-controls="rcb-details-{{ block.id }}">
      <span class="rcb-disclosure-text"
            data-closed="{{ block.settings.confirm_link_label | escape }}"
            data-open="{{ block.settings.confirm_link_label_open | escape }}">{{ block.settings.confirm_link_label | escape }}</span>
      <svg class="rcb-disclosure-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </button>
    <div class="rcb-details" id="rcb-details-{{ block.id }}"><div class="rcb-details-inner">{{ block.settings.confirm_details }}</div></div>
  {%- endif -%}
</div>

<script src="{{ 'rights-checkbox.js' | asset_url }}" defer></script>

{% schema %}
{"name":"Rights Checkbox","target":"section","settings":[
  {"type":"richtext","id":"checkbox_label","label":"Checkbox label","default":"<p>I have the right to use this design, and I agree to the <a href=\"#\">PrintLab Design Submission Agreement</a>.</p>"},
  {"type":"text","id":"confirm_link_label","label":"Disclosure link (collapsed)","default":"What I'm confirming"},
  {"type":"text","id":"confirm_link_label_open","label":"Disclosure link (expanded)","default":"Show less"},
  {"type":"richtext","id":"confirm_details","label":"What I'm confirming — details"}
]}
{% endschema %}
