{{ 'simple-banner.css' | asset_url | stylesheet_tag }}

<section class="sb-section"
         style="background:{{ block.settings.background_color }};color:{{ block.settings.text_color }};">
  <div class="sb-inner">

    {%- if block.settings.eyebrow != blank -%}
    <div class="sb-eyebrow" style="color:{{ block.settings.eyebrow_color }};">
      {{- block.settings.eyebrow -}}
    </div>
    {%- endif -%}

    <h2 class="sb-title">
      {{- block.settings.heading -}}
      {%- if block.settings.heading_emphasis != blank -%}
        <em style="color:{{ block.settings.emphasis_color }};">{{ block.settings.heading_emphasis }}</em>
      {%- endif -%}
    </h2>

    {%- if block.settings.subtext != blank -%}
    <div class="sb-sub">{{ block.settings.subtext }}</div>
    {%- endif -%}

    {%- if block.settings.btn1_label != blank or block.settings.btn2_label != blank -%}
    <div class="sb-ctas">

      {%- if block.settings.btn1_label != blank -%}
      <a href="{{ block.settings.btn1_url }}"
         class="sb-btn"
         style="--sb-text:{{ block.settings.btn1_text_color }};--sb-bg:{{ block.settings.btn1_bg_color }};--sb-border:{{ block.settings.btn1_border_color }};--sb-hover-text:{{ block.settings.btn1_hover_text_color }};--sb-hover-bg:{{ block.settings.btn1_hover_bg_color }};--sb-hover-border:{{ block.settings.btn1_hover_border_color }};">
        {{- block.settings.btn1_label -}}
      </a>
      {%- endif -%}

      {%- if block.settings.btn2_label != blank -%}
      <a href="{{ block.settings.btn2_url }}"
         class="sb-btn"
         style="--sb-text:{{ block.settings.btn2_text_color }};--sb-bg:{{ block.settings.btn2_bg_color }};--sb-border:{{ block.settings.btn2_border_color }};--sb-hover-text:{{ block.settings.btn2_hover_text_color }};--sb-hover-bg:{{ block.settings.btn2_hover_bg_color }};--sb-hover-border:{{ block.settings.btn2_hover_border_color }};">
        {{- block.settings.btn2_label -}}
      </a>
      {%- endif -%}

    </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Simple Banner",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Before you commit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See it. Feel it."
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasis (italic)",
      "default": "Then order metres."
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>A 25 × 25 cm swatch of your chosen design, shipped worldwide. The best test of fabric is the fabric itself.</p>"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F4E4DA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1A1814"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow",
      "default": "#B85C38"
    },
    {
      "type": "color",
      "id": "emphasis_color",
      "label": "Heading emphasis",
      "default": "#6B8F71"
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Label",
      "default": "Print a swatch of this design →"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "URL"
    },
    {
      "type": "color",
      "id": "btn1_text_color",
      "label": "Text colour",
      "default": "#B85C38"
    },
    {
      "type": "color",
      "id": "btn1_bg_color",
      "label": "Background colour",
      "default": "#F4E4DA"
    },
    {
      "type": "color",
      "id": "btn1_border_color",
      "label": "Border colour",
      "default": "#B85C38"
    },
    {
      "type": "color",
      "id": "btn1_hover_text_color",
      "label": "Hover text colour",
      "default": "#FAF8F3"
    },
    {
      "type": "color",
      "id": "btn1_hover_bg_color",
      "label": "Hover background colour",
      "default": "#B85C38"
    },
    {
      "type": "color",
      "id": "btn1_hover_border_color",
      "label": "Hover border colour",
      "default": "#B85C38"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Label",
      "default": "Order a Base Fabrics Pack →"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "URL"
    },
    {
      "type": "color",
      "id": "btn2_text_color",
      "label": "Text colour",
      "default": "#1A1814"
    },
    {
      "type": "color",
      "id": "btn2_bg_color",
      "label": "Background colour",
      "default": "#F4E4DA"
    },
    {
      "type": "color",
      "id": "btn2_border_color",
      "label": "Border colour",
      "default": "#1A1814"
    },
    {
      "type": "color",
      "id": "btn2_hover_text_color",
      "label": "Hover text colour",
      "default": "#FAF8F3"
    },
    {
      "type": "color",
      "id": "btn2_hover_bg_color",
      "label": "Hover background colour",
      "default": "#1A1814"
    },
    {
      "type": "color",
      "id": "btn2_hover_border_color",
      "label": "Hover border colour",
      "default": "#1A1814"
    }
  ]
}
{% endschema %}
