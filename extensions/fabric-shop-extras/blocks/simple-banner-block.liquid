{{ 'simple-banner.css' | asset_url | stylesheet_tag }}

<section class="sb-section"
         style="background:{{ block.settings.background_color }};color:{{ block.settings.text_color }};--eyebrow-size: {{ block.settings.eyebrow_font_size }}px;">
  <div class="sb-inner">

    {%- if block.settings.eyebrow != blank -%}
    <div class="sb-eyebrow" style="color:{{ block.settings.eyebrow_color }};">
      {{- block.settings.eyebrow -}}
    </div>
    {%- endif -%}

    <h2 class="sb-title">
      {{- block.settings.heading -}}
      {%- if block.settings.heading_emphasis != blank -%}
        <em style="color:{{ block.settings.emphasis_color }};">{{ block.settings.heading_emphasis }}</em>
      {%- endif -%}
    </h2>

    {%- if block.settings.subtext != blank -%}
    <div class="sb-sub">{{ block.settings.subtext }}</div>
    {%- endif -%}

    {%- assign any_cta = false -%}
    {%- if block.settings.btn1_label != blank or block.settings.btn2_label != blank or block.settings.btn3_label != blank -%}
      {%- assign any_cta = true -%}
    {%- endif -%}

    {%- if any_cta -%}
    <div class="sb-ctas">

      {%- for i in (1..3) -%}
        {%- assign lbl_key        = 'btn' | append: i | append: '_label' -%}
        {%- assign url_key        = 'btn' | append: i | append: '_url' -%}
        {%- assign type_key       = 'btn' | append: i | append: '_type' -%}
        {%- assign tc_key         = 'btn' | append: i | append: '_text_color' -%}
        {%- assign bg_key         = 'btn' | append: i | append: '_bg_color' -%}
        {%- assign bc_key         = 'btn' | append: i | append: '_border_color' -%}
        {%- assign htc_key        = 'btn' | append: i | append: '_hover_text_color' -%}
        {%- assign hbg_key        = 'btn' | append: i | append: '_hover_bg_color' -%}
        {%- assign hbc_key        = 'btn' | append: i | append: '_hover_border_color' -%}
        {%- assign lbl  = block.settings[lbl_key] -%}
        {%- assign url  = block.settings[url_key] | default: '#' -%}
        {%- assign type = block.settings[type_key] -%}
        {%- if lbl != blank -%}
          {%- if type == 'link' -%}
          <a href="{{ url }}"
             class="sb-link"
             style="--sb-text:{{ block.settings[tc_key] }};--sb-hover-text:{{ block.settings[htc_key] }};">
            {{- lbl -}}
          </a>
          {%- else -%}
          <a href="{{ url }}"
             class="sb-btn"
             style="--sb-text:{{ block.settings[tc_key] }};--sb-bg:{{ block.settings[bg_key] }};--sb-border:{{ block.settings[bc_key] }};--sb-hover-text:{{ block.settings[htc_key] }};--sb-hover-bg:{{ block.settings[hbg_key] }};--sb-hover-border:{{ block.settings[hbc_key] }};">
            {{- lbl -}}
          </a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

    </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{"name":"Simple Banner","target":"section","settings":[
  {"type":"header","content":"Content"},
  {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Before you commit"},
  {"type":"range","id":"eyebrow_font_size","label":"Eyebrow font size","min":8,"max":20,"step":1,"unit":"px","default":13},
  {"type":"text","id":"heading","label":"Heading","default":"See it. Feel it."},
  {"type":"text","id":"heading_emphasis","label":"Heading emphasis (italic)","default":"Then order metres."},
  {"type":"richtext","id":"subtext","label":"Subtext","default":"<p>A 25 × 25 cm swatch of your chosen design, shipped worldwide. The best test of fabric is the fabric itself.</p>"},
  {"type":"header","content":"Colours"},
  {"type":"color","id":"background_color","label":"Background","default":"#F4E4DA"},
  {"type":"color","id":"text_color","label":"Text","default":"#1A1814"},
  {"type":"color","id":"eyebrow_color","label":"Eyebrow","default":"#B85C38"},
  {"type":"color","id":"emphasis_color","label":"Heading emphasis","default":"#6B8F71"},
  {"type":"header","content":"CTA 1"},
  {"type":"select","id":"btn1_type","label":"Style","options":[{"value":"button","label":"Button"},{"value":"link","label":"Text link"}],"default":"button"},
  {"type":"text","id":"btn1_label","label":"Label","default":"Print a swatch of this design →"},
  {"type":"url","id":"btn1_url","label":"URL"},
  {"type":"color","id":"btn1_text_color","label":"Text","default":"#B85C38"},
  {"type":"color","id":"btn1_bg_color","label":"Background","default":"#F4E4DA"},
  {"type":"color","id":"btn1_border_color","label":"Border","default":"#B85C38"},
  {"type":"color","id":"btn1_hover_text_color","label":"Hover text","default":"#FAF8F3"},
  {"type":"color","id":"btn1_hover_bg_color","label":"Hover BG","default":"#B85C38"},
  {"type":"color","id":"btn1_hover_border_color","label":"Hover border","default":"#B85C38"},
  {"type":"header","content":"CTA 2"},
  {"type":"select","id":"btn2_type","label":"Style","options":[{"value":"button","label":"Button"},{"value":"link","label":"Text link"}],"default":"button"},
  {"type":"text","id":"btn2_label","label":"Label","default":"Order a Base Fabrics Pack →"},
  {"type":"url","id":"btn2_url","label":"URL"},
  {"type":"color","id":"btn2_text_color","label":"Text","default":"#1A1814"},
  {"type":"color","id":"btn2_bg_color","label":"Background","default":"#F4E4DA"},
  {"type":"color","id":"btn2_border_color","label":"Border","default":"#1A1814"},
  {"type":"color","id":"btn2_hover_text_color","label":"Hover text","default":"#FAF8F3"},
  {"type":"color","id":"btn2_hover_bg_color","label":"Hover BG","default":"#1A1814"},
  {"type":"color","id":"btn2_hover_border_color","label":"Hover border","default":"#1A1814"},
  {"type":"header","content":"CTA 3"},
  {"type":"select","id":"btn3_type","label":"Style","options":[{"value":"button","label":"Button"},{"value":"link","label":"Text link"}],"default":"button"},
  {"type":"text","id":"btn3_label","label":"Label"},
  {"type":"url","id":"btn3_url","label":"URL"},
  {"type":"color","id":"btn3_text_color","label":"Text","default":"#1A1814"},
  {"type":"color","id":"btn3_bg_color","label":"Background","default":"#FAF8F3"},
  {"type":"color","id":"btn3_border_color","label":"Border","default":"#1A1814"},
  {"type":"color","id":"btn3_hover_text_color","label":"Hover text","default":"#FAF8F3"},
  {"type":"color","id":"btn3_hover_bg_color","label":"Hover BG","default":"#1A1814"},
  {"type":"color","id":"btn3_hover_border_color","label":"Hover border","default":"#1A1814"}
]}
{% endschema %}
