{{ 'part-of-collection.css' | asset_url | stylesheet_tag }}
{{ 'fp-colour-popover.css' | asset_url | stylesheet_tag }}
<script src="{{ 'fp-colour-popover.js' | asset_url }}" defer></script>

<div id="poc-root"
     style="--eyebrow-size: {{ block.settings.eyebrow_font_size }}px;"
     data-product-gid="{{ product.id | prepend: 'gid://shopify/Product/' }}"
     data-proxy-base="/apps/fabric-shop/api">
  <section class="poc-section poc-skeleton">
    <div class="poc-inner">
      <div class="poc-head">
        <div class="poc-cover poc-skel-block"></div>
        <div class="poc-text">
          <div class="poc-skel-line poc-skel-line--eyebrow"></div>
          <div class="poc-skel-line poc-skel-line--title"></div>
          <div class="poc-skel-line poc-skel-line--title poc-skel-line--title-short"></div>
          <div class="poc-skel-line poc-skel-line--meta"></div>
          <div class="poc-skel-line poc-skel-line--body"></div>
          <div class="poc-skel-line poc-skel-line--body"></div>
          <div class="poc-skel-line poc-skel-line--body poc-skel-line--body-short"></div>
          <div class="poc-skel-line poc-skel-line--cta"></div>
        </div>
      </div>
      <div class="poc-grid">
        {%- for i in (1..4) -%}
        <div class="poc-card poc-skel-card">
          <div class="poc-card-image poc-skel-block"></div>
          <div class="poc-card-info">
            <div class="poc-skel-line poc-skel-line--card-title"></div>
            <div class="poc-skel-line poc-skel-line--card-meta"></div>
          </div>
        </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>

<script>
(function () {
  var CACHE_TTL = 30 * 60 * 1000; // 30 minutes
  var root = document.getElementById('poc-root');
  if (!root) return;

  var productGid = root.dataset.productGid;
  var proxyBase  = root.dataset.proxyBase;
  var cacheKey   = 'poc:' + productGid;

  function render(data) {
    var col = data.collection;
    if (!col) { root.style.display = 'none'; return; }

    var coverHtml = '';
    var coverClass = 'poc-cover';

    if (col.coverType === 'auto_mosaic' && col.previewImages && col.previewImages.length > 1) {
      coverHtml = '<div class="poc-mosaic">';
      col.previewImages.slice(0, 4).forEach(function (url) {
        coverHtml += '<img class="poc-mosaic__img" src="' + url + '" alt="" loading="lazy">';
      });
      coverHtml += '</div>';
    } else if (col.coverImageUrl) {
      coverHtml = '<img class="poc-cover-img" src="' + escHtml(col.coverImageUrl) + '" alt="' + escHtml(col.title) + '" loading="lazy">';
    } else {
      coverClass = 'poc-cover poc-cover--placeholder';
    }

    var designerMeta = col.designer ? ' · by ' + escHtml(col.designer.name) : '';
    var descHtml = col.description
      ? '<p class="poc-description">' + escHtml(col.description) + '</p>'
      : '';

    var ctaHref = col.designer
      ? '/pages/partners?handle=' + encodeURIComponent(col.designer.slug) + '&tab=collection&slug=' + encodeURIComponent(col.handle)
      : '/collections/' + escHtml(col.handle);

    var gridHtml = '';
    if (col.otherProducts && col.otherProducts.length) {
      gridHtml = '<div class="poc-grid">';
      col.otherProducts.forEach(function (p) {
        var thumbHtml = p.imageUrl
          ? '<img src="' + escHtml(p.imageUrl) + '" alt="' + escHtml(p.title) + '" loading="lazy">'
          : '';
        // Colour options — replaces the old scale/repeat meta. Shown only when
        // a design has more than one colourway; opens an anchored popover whose
        // swatches deep-link to the PDP with the colour preselected.
        var colours = Array.isArray(p.colours) ? p.colours : [];
        var metaHtml = '';
        if (colours.length > 1) {
          var dotsHtml = colours.slice(0, 3).map(function (c) {
            return '<span class="poc-colours-dot"' +
              (c.image ? ' style="background-image:url(\'' + escHtml(c.image) + '\')"' : '') + '></span>';
          }).join('');
          metaHtml =
            '<div class="poc-card-colours">' +
              '<button class="poc-colours-toggle" type="button"' +
                ' data-handle="' + escHtml(p.handle) + '"' +
                ' data-colours="' + escHtml(JSON.stringify(colours)) + '">' +
                '<span class="poc-colours-dots">' + dotsHtml + '</span>' +
                '<span class="poc-colours-count">' + colours.length + ' Colors</span>' +
                '<svg class="poc-colours-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>' +
              '</button>' +
            '</div>';
        }
        gridHtml +=
          '<a class="cg-card poc-card" href="/products/' + escHtml(p.handle) + '"' +
            ' data-product-id="' + escHtml(p.numericId) + '"' +
            ' data-like-count="0">' +
            '<div class="cg-card-image poc-card-image">' + thumbHtml + '</div>' +
            '<div class="poc-card-info">' +
              '<h2 class="poc-card-title">' + escHtml(p.title) + '</h2>' +
              metaHtml +
            '</div>' +
          '</a>';
      });
      gridHtml += '</div>';
    }

    root.innerHTML =
      '<section class="poc-section">' +
        '<div class="poc-inner">' +
          '<div class="poc-head">' +
            '<div class="' + coverClass + '">' + coverHtml + '</div>' +
            '<div class="poc-text">' +
              '<div class="poc-eyebrow">Part of a collection</div>' +
              '<h2 class="poc-name">' + escHtml(col.title) + '</h2>' +
              '<div class="poc-meta">' + escHtml(String(col.productsCount)) + ' designs' + designerMeta + '</div>' +
              descHtml +
              '<a class="poc-cta" href="' + ctaHref + '">View the full collection →</a>' +
            '</div>' +
          '</div>' +
          gridHtml +
        '</div>' +
      '</section>';

    // Bind colour-option popovers
    root.querySelectorAll('.poc-colours-toggle').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        var cols;
        try { cols = JSON.parse(btn.getAttribute('data-colours') || '[]'); } catch (err) { cols = []; }
        if (window.FPColourPopover) {
          window.FPColourPopover.open(btn.getAttribute('data-handle'), cols, btn, btn.closest('.poc-card'));
        }
      });
    });

    if (typeof window.__fpReinjectCards === 'function') {
      window.__fpReinjectCards();
    }
  }

  // Check browser cache first
  try {
    var cached = sessionStorage.getItem(cacheKey);
    if (cached) {
      var parsed = JSON.parse(cached);
      if (parsed.expiresAt > Date.now()) {
        render(parsed.data);
        return;
      }
      sessionStorage.removeItem(cacheKey);
    }
  } catch (e) { /* sessionStorage unavailable */ }

  // Fetch from API
  fetch(proxyBase + '/product-collection?product_gid=' + encodeURIComponent(productGid))
    .then(function (r) { return r.json(); })
    .then(function (data) {
      try {
        sessionStorage.setItem(cacheKey, JSON.stringify({ data: data, expiresAt: Date.now() + CACHE_TTL }));
      } catch (e) { /* storage full or blocked */ }
      render(data);
    })
    .catch(function () { root.style.display = 'none'; });

  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
})();
</script>

{% schema %}
{"name":"Part of a Collection","target":"section","settings":[
  {"type":"range","id":"eyebrow_font_size","label":"Eyebrow font size","min":8,"max":20,"step":1,"unit":"px","default":13}
]}
{% endschema %}
