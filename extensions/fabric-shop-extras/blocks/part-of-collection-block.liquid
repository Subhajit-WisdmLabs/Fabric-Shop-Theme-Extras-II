{{ 'part-of-collection.css' | asset_url | stylesheet_tag }}

<div id="poc-root"
     data-product-gid="{{ product.id | prepend: 'gid://shopify/Product/' }}"
     data-proxy-base="/apps/fabric-shop/api"
     style="display:none">
</div>

<script>
(function () {
  var root = document.getElementById('poc-root');
  if (!root) return;

  var productGid = root.dataset.productGid;
  var proxyBase  = root.dataset.proxyBase;

  fetch(proxyBase + '/product-collection?product_gid=' + encodeURIComponent(productGid))
    .then(function (r) { return r.json(); })
    .then(function (data) {
      var col = data.collection;
      if (!col) return; // product has no partner collection — stay hidden

      var coverHtml = col.coverImageUrl
        ? '<img class="poc-cover-img" src="' + col.coverImageUrl + '" alt="' + escHtml(col.title) + '" loading="lazy">'
        : '';
      var coverClass = col.coverImageUrl ? 'poc-cover' : 'poc-cover poc-cover--placeholder';

      var designerMeta = col.designer ? ' · by ' + escHtml(col.designer.name) : '';
      var descHtml = col.description
        ? '<p class="poc-description">' + escHtml(col.description) + '</p>'
        : '';

      var ctaHref = '/collections/' + escHtml(col.handle);

      var gridHtml = '';
      if (col.otherProducts && col.otherProducts.length) {
        gridHtml = '<div class="poc-grid">';
        col.otherProducts.forEach(function (p) {
          var thumbHtml = p.imageUrl
            ? '<img src="' + p.imageUrl + '" alt="' + escHtml(p.title) + '" loading="lazy">'
            : '';
          var thumbClass = p.imageUrl ? 'poc-card-thumb' : 'poc-card-thumb poc-card-thumb--placeholder';
          var priceHtml = p.minPrice
            ? '<div class="poc-card-price">from ' + formatPrice(p.minPrice, p.currencyCode) + '</div>'
            : '';
          gridHtml +=
            '<a class="poc-card" href="/products/' + escHtml(p.handle) + '">' +
              '<div class="' + thumbClass + '">' + thumbHtml + '</div>' +
              '<div class="poc-card-meta">' +
                '<div class="poc-card-title">' + escHtml(p.title) + '</div>' +
                priceHtml +
              '</div>' +
            '</a>';
        });
        gridHtml += '</div>';
      }

      root.innerHTML =
        '<section class="poc-section">' +
          '<div class="poc-inner">' +
            '<div class="poc-head">' +
              '<div class="' + coverClass + '">' + coverHtml + '</div>' +
              '<div class="poc-text">' +
                '<div class="poc-eyebrow">Part of a collection</div>' +
                '<h2 class="poc-name">' + escHtml(col.title) + '</h2>' +
                '<div class="poc-meta">' + col.productsCount + ' designs' + designerMeta + '</div>' +
                descHtml +
                '<a class="poc-cta" href="' + ctaHref + '">View the full collection →</a>' +
              '</div>' +
            '</div>' +
            gridHtml +
          '</div>' +
        '</section>';

      root.style.display = '';
    })
    .catch(function () { /* stay hidden on error */ });

  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function formatPrice(amount, currency) {
    try {
      return new Intl.NumberFormat(undefined, { style: 'currency', currency: currency, minimumFractionDigits: 2 }).format(parseFloat(amount));
    } catch (e) {
      return currency + ' ' + parseFloat(amount).toFixed(2);
    }
  }
})();
</script>

{% schema %}
{
  "name": "Part of a Collection",
  "target": "section",
  "settings": []
}
{% endschema %}
